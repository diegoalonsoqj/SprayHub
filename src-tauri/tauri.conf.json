{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SprayHub",
  "version": "0.1.0",
  "identifier": "com.diegoalonsoqj.sprayhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SprayHub",
        "width": 840,
        "height": 580,
        "minWidth": 560,
        "minHeight": 420,
        "resizable": true,
        "center": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Manage Source Engine sprays",
    "longDescription": "Professional cross-platform suite for managing Source Engine sprays (.vtf + .vmt): browse, preview and apply sprays to your games."
  },
  "plugins": {}
}
